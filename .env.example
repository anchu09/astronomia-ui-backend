# Copia a .env y ajusta valores.
# Para dev local: GALAXY_API_URL=http://localhost:8000
# Para Docker: GALAXY_API_URL=http://host.docker.internal:8000

# Modo de orquestacion: auto (router LLM), direct (solo Galaxy API), n8n (solo n8n)
ORCHESTRATOR_MODE=auto
GALAXY_API_URL=http://localhost:8000
GALAXY_API_KEY=
N8N_WEBHOOK_URL=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OpenAI (requerido para modo auto)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
